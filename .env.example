# Continuity — AI provider configuration (server-side only).
# Copy to .env.local for local dev, or set these in your Vercel project settings.
# These are read ONLY on the server. Never use a NEXT_PUBLIC_ prefix for keys.

# Which provider to use. Optional — if unset, the first key present is used.
# AI_PROVIDER=anthropic   # or: openai | openrouter

# Anthropic (recommended for privacy — no training on API data by default)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenRouter (one key, many models — including free tiers). Key: https://openrouter.ai/keys
# NOTE: free (":free") models may log prompts and use them for training — fine for
# testing, NOT for sensitive context. You may also need to enable the free-model
# data policy under OpenRouter → Settings → Privacy.
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# Default (stable, structured-output friendly, free):
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Other free options — paste the EXACT slug from the model's OpenRouter page:
#   OPENROUTER_MODEL=openai/gpt-oss-20b:free     # smaller / faster
#   OPENROUTER_MODEL=openrouter/owl-alpha        # agentic, 1M ctx (alpha: may change or be removed)

# With no key configured, Continuity does NOT fake drafts. It shows an honest
# "not configured" state and still assembles + lets you copy the exact prompt.
